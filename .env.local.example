# ─────────────────────────────────────────────────────────────
# COPY THIS FILE TO .env.local AND FILL IN YOUR VALUES
# NEXT_PUBLIC_ prefix = exposed to the browser (required here
# because we are calling Power Automate from the client side)
# ─────────────────────────────────────────────────────────────

# Google Analytics 4 Measurement ID
# Get it from: analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Power Automate HTTP trigger URL
# Get it from: Power Automate → your flow → HTTP trigger card
NEXT_PUBLIC_PAD_WEBHOOK_URL=https://prod-xx.westeurope.logic.azure.com:443/workflows/YOUR_FLOW_URL
